# ===========================================
# Servidor
# ===========================================
# Em Railway/Heroku/etc. use PORT (injetada pela plataforma). Localmente use HOST_PORT.
HOST_PORT=3000

# ===========================================
# Banco de Dados (use DATABASE_URL ou DB_*)
# ===========================================
DATABASE_URL=postgresql://user:password@host:port/dbname?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_NAME=vidwave

TRANSCRIBE_HOST=http://57.156.32.8:8000

# ===========================================
# Autenticação JWT
# ===========================================
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_EXPIRES_IN=7d

# ===========================================
# Redis (fila BullMQ) — com REDISCLOUD_URL preenchido, host/port locais são ignorados
# ===========================================
REDISCLOUD_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# Armazenamento
# ===========================================
UPLOAD_PATH=./uploads
STORAGE_PATH=./storage

# ===========================================
# Google Tradutor (credenciais: painel Manage → Configurações → Google)
# ===========================================
GOOGLE_TRANSLATE_CREDENTIALS_KEY=GOOGLE_TRANSLATE_CREDENTIALS_JSON
GOOGLE_TRANSLATE_BASE=https://translation.googleapis.com/language/translate/v2
# Segmentos por requisição ao traduzir listas (máx. 500). Se a API retornar erro, tente 128.
GOOGLE_TRANSLATE_Q_BATCH_SIZE=100
# Quantidade de requisições paralelas por lote na tradução de segmentos.
GOOGLE_TRANSLATE_PARALLEL_REQUESTS=5
GOOGLE_CLOUD_SCOPE=https://www.googleapis.com/auth/cloud-platform

# ===========================================
# Seed - Administrador (somente via migration/seed)
# ===========================================
MANAGER_EMAIL=gustavojose321@gmail.com
MANAGER_PASSWORD=react8129