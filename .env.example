# ===========================================
# Conexões (URLs principais)
# ===========================================
# PostgreSQL — tem prioridade sobre DB_* quando preenchida
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Redis — BullMQ (fila interna). Se vazio, usa REDIS_HOST / REDIS_PORT
REDISCLOUD_URL=

# RabbitMQ — transcrição via fila Whisper (amqp://user:pass@host:5672/)
# Deixe vazio para usar TRANSCRIBE_HOST (API HTTP) em vez da fila
RABBITMQ_URL=

# ===========================================
# Servidor
# ===========================================
# Em Railway/Heroku use PORT (injetada). Localmente: HOST_PORT ou PORT
HOST_PORT=3000

# ===========================================
# Banco de Dados (fallback se DATABASE_URL vazia)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=vidwave

# ===========================================
# Transcrição Whisper
# ===========================================
# API HTTP (legado) — ignorado se RABBITMQ_URL estiver definido
TRANSCRIBE_HOST=http://localhost:8000
# Com RABBITMQ_URL, use uma das opções:
# (A) URL assinada — worker baixa o áudio via HTTP (PUBLIC_APP_URL acessível pelo container, ex.: http://host.docker.internal:3000)
PUBLIC_APP_URL=
WHISPER_MQ_DOWNLOAD_SECRET=
# TTL da URL em segundos (60–604800)
WHISPER_MQ_DOWNLOAD_TTL_SEC=3600
# (B) Volume compartilhado — mesmo caminho absoluto no Nest e no worker
TRANSCRIPTION_SHARED_STORAGE_PATH=
WHISPER_JOBS_QUEUE=nest_whisper_jobs
WHISPER_STATUS_QUEUE=nest_whisper_status

# ===========================================
# Autenticação JWT
# ===========================================
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_EXPIRES_IN=7d

# ===========================================
# Redis (local, se REDISCLOUD_URL vazio)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===========================================
# Armazenamento
# ===========================================
UPLOAD_PATH=./uploads
STORAGE_PATH=./storage

# ===========================================
# Google Tradutor
# ===========================================
GOOGLE_TRANSLATE_CREDENTIALS_KEY=GOOGLE_TRANSLATE_CREDENTIALS_JSON
GOOGLE_TRANSLATE_BASE=https://translation.googleapis.com/language/translate/v2
GOOGLE_TRANSLATE_Q_BATCH_SIZE=100
GOOGLE_TRANSLATE_PARALLEL_REQUESTS=5
GOOGLE_CLOUD_SCOPE=https://www.googleapis.com/auth/cloud-platform

# ===========================================
# Seed / administrador (prisma db seed; /internal/initial-seed)
# ===========================================
MANAGER_EMAIL=
MANAGER_PASSWORD=
INITIAL_SEED_SECRET=
